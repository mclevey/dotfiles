{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(*)",
      "Write(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Bash(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(pip install *)",
      "Bash(git checkout -- *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(git branch -D *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [ \"${file##*.}\" = \"py\" ] && command -v ruff >/dev/null 2>&1; then ruff format --quiet \"$file\" || echo \"[hook] ruff format failed: $file\"; ruff check --fix --quiet \"$file\" || echo \"[hook] ruff check failed: $file\"; fi; exit 0"
          }
        ]
      }
    ]
  }
}